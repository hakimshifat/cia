---
import Layout from '../layouts/Layout.astro';
---
<Layout title="CIA">
<section id="education" class="section-pad">
  <div class="section-header reveal" style="position:relative;z-index:2">
    <div class="section-eyebrow">System Info</div>
    <h2 class="section-title">Base of <span>Operations</span></h2>
  </div>
  <div class="edu-terminals">
    <div class="edu-terminal reveal">
      <div class="edu-terminal-header">
        <div class="edu-terminal-dots">
          <span style="background:#ff5f57"></span>
          <span style="background:#febc2e"></span>
          <span style="background:#28c840"></span>
        </div>
        <div class="edu-terminal-title">institution.cfg</div>
      </div>
      <div class="edu-terminal-body">
        <div class="edu-terminal-row">
          <span class="edu-t-key">NAME</span>
          <span class="edu-t-val">Bangladesh University of Professionals</span>
        </div>
        <div class="edu-terminal-row">
          <span class="edu-t-key">TYPE</span>
          <span class="edu-t-val">Home Institution</span>
        </div>
        <div class="edu-terminal-row">
          <span class="edu-t-key">LOCATION</span>
          <span class="edu-t-val">Mirpur Cantonment, Dhaka 🇧🇩</span>
        </div>
        <div class="edu-terminal-row">
          <span class="edu-t-key">STATUS</span>
          <span class="edu-t-val edu-t-active">● ACTIVE — EST. 2025</span>
        </div>
      </div>
    </div>
    <div class="edu-terminal reveal reveal-delay-1">
      <div class="edu-terminal-header">
        <div class="edu-terminal-dots">
          <span style="background:#ff5f57"></span>
          <span style="background:#febc2e"></span>
          <span style="background:#28c840"></span>
        </div>
        <div class="edu-terminal-title">platform.cfg</div>
      </div>
      <div class="edu-terminal-body">
        <div class="edu-terminal-row">
          <span class="edu-t-key">PLATFORM</span>
          <span class="edu-t-val"><a href="https://ctftime.org/team/408973" target="_blank" class="edu-link">CTFtime</a></span>
        </div>
        <div class="edu-terminal-row">
          <span class="edu-t-key">TEAM_ID</span>
          <span class="edu-t-val">#408973</span>
        </div>
        <div class="edu-terminal-row">
          <span class="edu-t-key">SCOPE</span>
          <span class="edu-t-val">Global Competitive Community</span>
        </div>
        <div class="edu-terminal-row">
          <span class="edu-t-key">STATUS</span>
          <span class="edu-t-val edu-t-active">● ACTIVE — 2025–2026</span>
        </div>
      </div>
    </div>
  </div>
  <div class="lang-section reveal" style="position:relative;z-index:2">
    <div class="lang-section-title">Competition Domains</div>
    <div class="lang-badges">
      <span class="lang-badge lang-indigo">Web Exploitation</span>
      <span class="lang-badge lang-pink">Cryptography</span>
      <span class="lang-badge lang-cyan">Reverse Engineering</span>
      <span class="lang-badge lang-amber">Binary Exploitation</span>
      <span class="lang-badge lang-indigo">OSINT</span>
      <span class="lang-badge lang-pink">Forensics</span>
      <span class="lang-badge lang-cyan">Steganography</span>
      <span class="lang-badge lang-amber">Malware Analysis</span>
      <span class="lang-badge lang-indigo">Network Security</span>
    </div>
  </div>
</section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
const getPosition = (rankStr) => {
  if (!rankStr) return 999;
  const num = parseInt(rankStr.replace(/\D/g, ''), 10);
  return isNaN(num) ? 999 : num;
};

const all = Object.values(import.meta.glob('../achievements/*.md', { eager: true }));
const international = all.filter(p => p.frontmatter.category === 'international').sort((a, b) => getPosition(a.frontmatter.rank) - getPosition(b.frontmatter.rank));
const national = all.filter(p => p.frontmatter.category === 'national').sort((a, b) => getPosition(a.frontmatter.rank) - getPosition(b.frontmatter.rank));
---
<Layout title="Competitions - CIA">
<section id="competitions" class="section-pad">
  <div class="section-header reveal">
    <div class="section-eyebrow">Competitions</div>
    <h2 class="section-title">Hollow <span>Purification Log</span></h2>
    <p class="section-desc">Every competition we entered, every Hollow we defeated, every flag we captured — recorded here.</p>
  </div>

  <!-- ── National Battles ── -->
  <div class="battle-subsection reveal">
    <div class="battle-subsection-header">
      <h3 class="battle-subsection-title">National Battles</h3>
      <span class="battle-subsection-tag">{national.length} Operations</span>
    </div>
    <div class="projects-grid">
      {national.map(proj => (
        <div class="project-card reveal">
          <span class={`project-rank ${proj.frontmatter.rank_class}`}>{proj.frontmatter.rank}</span>
          <div class="project-card-image">
            {getPosition(proj.frontmatter.rank) !== 999 && (
              <span class="project-bg-number">
                {getPosition(proj.frontmatter.rank) < 10 ? `0${getPosition(proj.frontmatter.rank)}` : getPosition(proj.frontmatter.rank)}
              </span>
            )}
            {proj.frontmatter.image ? (
              <img src={proj.frontmatter.image} alt={proj.frontmatter.title} loading="lazy" />
            ) : (
              <span class="project-emoji-placeholder">{proj.frontmatter.emoji}</span>
            )}
          </div>
          <div class="project-card-body">
            <h3 class="project-title">{proj.frontmatter.title}</h3>
            <p class="project-desc"><proj.Content /></p>
            <div class="project-tags">
              {proj.frontmatter.tags && proj.frontmatter.tags.map(tag => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>
            {proj.frontmatter.collab_logos && (
              <div class="collab-logos-container">
                <span class="collab-text">Partnered with:</span>
                <div class="collab-logos">
                  {proj.frontmatter.collab_logos.map(logo => (
                    <img src={logo} alt="Collaborator Logo" class="collab-logo-img" />
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- ── International Battles ── -->
  <div class="battle-subsection reveal" style="margin-top:64px;">
    <div class="battle-subsection-header">
      <h3 class="battle-subsection-title">International Battles</h3>
      <span class="battle-subsection-tag">{international.length} Operations</span>
    </div>
    <div class="projects-grid">
      {international.map(proj => (
        <div class="project-card reveal">
          <span class={`project-rank ${proj.frontmatter.rank_class}`}>{proj.frontmatter.rank}</span>
          <div class="project-card-image">
            {getPosition(proj.frontmatter.rank) !== 999 && (
              <span class="project-bg-number">
                {getPosition(proj.frontmatter.rank) < 10 ? `0${getPosition(proj.frontmatter.rank)}` : getPosition(proj.frontmatter.rank)}
              </span>
            )}
            {proj.frontmatter.image ? (
              <img src={proj.frontmatter.image} alt={proj.frontmatter.title} loading="lazy" />
            ) : (
              <span class="project-emoji-placeholder">{proj.frontmatter.emoji}</span>
            )}
          </div>
          <div class="project-card-body">
            <h3 class="project-title">{proj.frontmatter.title}</h3>
            <p class="project-desc"><proj.Content /></p>
            <div class="project-tags">
              {proj.frontmatter.tags && proj.frontmatter.tags.map(tag => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>
            {proj.frontmatter.collab_logos && (
              <div class="collab-logos-container">
                <span class="collab-text">Partnered with:</span>
                <div class="collab-logos">
                  {proj.frontmatter.collab_logos.map(logo => (
                    <img src={logo} alt="Collaborator Logo" class="collab-logo-img" />
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
const crew = Object.values(import.meta.glob('../crew/*.md', { eager: true }));
const founders = crew.filter(m => m.frontmatter.type === 'founder').sort((a, b) => (a.frontmatter.order ?? 999) - (b.frontmatter.order ?? 999));
const members = crew.filter(m => m.frontmatter.type === 'member').sort((a, b) => (a.frontmatter.order ?? 999) - (b.frontmatter.order ?? 999));
const advisors = crew.filter(m => m.frontmatter.type === 'advisor').sort((a, b) => (a.frontmatter.order ?? 999) - (b.frontmatter.order ?? 999));
---
<Layout title="Shinigami - CIA">
<section id="members" class="section-pad">
  <div class="section-header reveal">
    <div class="section-eyebrow">The Gotei</div>
    <h2 class="section-title">Our <span>Shinigami</span></h2>
    <p class="section-desc">The soul reapers behind every solve, sprint, and late-night exploit.</p>
  </div>
  <div class="member-groups">
    <div class="member-group reveal">
      <div class="member-group-header">
        <div>
          <div class="member-group-title">Captains</div>
          <p class="member-group-copy">The three captains who forged Cyber Invasion Army and set the pace for the entire squad.</p>
        </div>
        <span class="member-group-tag">{founders.length} Captains</span>
      </div>
      <div class="members-grid">
        {founders.map(member => (
          <div class="member-card">
            <img class="founder-photo" src={member.frontmatter.image} alt={member.frontmatter.name}/>
            <div class="member-name">{member.frontmatter.name}</div>
            <div class="member-handle">{member.frontmatter.handle}</div>
            <span class="member-role role-founder">Captain</span>
            <div class="founder-expertise">
              {member.frontmatter.expertise && member.frontmatter.expertise.map(exp => (
                <span>{exp}</span>
              ))}
            </div>
            <div class="founder-socials">
              {member.frontmatter.socials && member.frontmatter.socials.map(soc => (
                <a href={soc.url} target="_blank">{soc.label}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
    
    <div class="member-group reveal reveal-delay-1">
      <div class="member-group-header">
        <div>
          <div class="member-group-title">Lieutenants</div>
          <p class="member-group-copy">The wider squad handling the grind across web, crypto, reversing, OSINT, and every battleground we step into.</p>
        </div>
        <span class="member-group-tag">{members.length} Lieutenants</span>
      </div>
      <div class="members-grid">
        {members.map(member => (
          <div class="member-card">
            <img class="founder-photo" src={member.frontmatter.image} alt={member.frontmatter.name}/>
            <div class="member-name">{member.frontmatter.name}</div>
            <div class="member-handle">{member.frontmatter.handle}</div>
            <div class="founder-expertise">
              {member.frontmatter.expertise && member.frontmatter.expertise.map(exp => (
                <span>{exp}</span>
              ))}
            </div>
            <div class="founder-socials">
              {member.frontmatter.socials && member.frontmatter.socials.map(soc => (
                <a href={soc.url} target="_blank">{soc.label}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ── Head Captain Section ── -->
{advisors.map(adv => (
<section id="advisor">
  <div class="advisor-watermark">総隊長</div>
  <div class="advisor-inner">
    <div class="advisor-photo-side reveal">
      <img src={adv.frontmatter.image} alt={adv.frontmatter.name}/>
    </div>
    <div class="advisor-text-side reveal reveal-delay-1">
      <div class="advisor-label">Head Captain · 総隊長</div>
      <div class="advisor-name">{adv.frontmatter.name}</div>
      <div class="advisor-divider"></div>
      <div class="advisor-role">{adv.frontmatter.role}</div>
      <div class="advisor-expertise-label">Zanpakutō Abilities</div>
      <div class="advisor-expertise">
        {adv.frontmatter.expertise && adv.frontmatter.expertise.map(exp => (
          <span class="advisor-expertise-tag">{exp}</span>
        ))}
      </div>
    </div>
  </div>
</section>
))}
</Layout>

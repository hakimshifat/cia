---
import Layout from '../layouts/Layout.astro';
---
<Layout title="CIA">
<section id="gallery" class="section-pad">
  <div class="section-header reveal">
    <div class="section-eyebrow">Archives</div>
    <h2 class="section-title">Memory <span>Fragments</span></h2>
    <p class="section-desc">Captured moments from the squad — snapshots from training grounds and battlefields alike.</p>
  </div>
  <div class="gallery-grid">
    <figure class="gallery-card featured reveal">
      <img class="gallery-media" src="/cia/assets/images/gallery/IMG_8149.JPG.jpeg" alt="Cyber Invasion Army gallery photo IMG 8149"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-1">
      <img class="gallery-media" src="/cia/assets/images/gallery/IMG_8155.JPEG" alt="Cyber Invasion Army gallery photo IMG 8155" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-2">
      <img class="gallery-media" src="/cia/assets/images/gallery/IMG_8133.jpg" alt="Cyber Invasion Army gallery photo IMG 8133" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-3">
      <img class="gallery-media" src="/cia/assets/images/gallery/IMG_8119.jpg" alt="Cyber Invasion Army gallery photo IMG 8119" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal">
      <img class="gallery-media" src="/cia/assets/images/gallery/IMG_8046.jpg" alt="Cyber Invasion Army gallery photo IMG 8046" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-1">
      <img class="gallery-media" src="/cia/assets/images/gallery/IMG_7303.jpg" alt="Cyber Invasion Army gallery photo IMG 7303" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-2">
      <img class="gallery-media" src="/cia/assets/images/gallery/IMG_6809.jpg" alt="Cyber Invasion Army gallery photo IMG 6809" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-3">
      <img class="gallery-media" src="/cia/assets/images/gallery/IMG_3614.jpg" alt="Cyber Invasion Army gallery photo IMG 3614" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal">
      <img class="gallery-media" src="/cia/assets/images/gallery/event1.jpeg" alt="Cyber Invasion Army gallery photo event 1" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-1">
      <img class="gallery-media" src="/cia/assets/images/gallery/event2.jpeg" alt="Cyber Invasion Army gallery photo event 2" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-2">
      <img class="gallery-media" src="/cia/assets/images/gallery/event3.jpeg" alt="Cyber Invasion Army gallery photo event 3" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-3">
      <img class="gallery-media" src="/cia/assets/images/gallery/event4.jpeg" alt="Cyber Invasion Army gallery photo event 4" loading="lazy"/>
    </figure>
  </div>
</section>
</Layout>

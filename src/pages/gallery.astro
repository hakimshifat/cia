---
import Layout from '../layouts/Layout.astro';
---
<Layout title="CIA">
<section id="gallery" class="section-pad">
  <div class="section-header reveal">
    <div class="section-eyebrow">Gallery</div>
    <h2 class="section-title">Mission <span>Snapshots</span></h2>
    <p class="section-desc">Real moments from the team, led by the latest shots from your gallery folder.</p>
  </div>
  <div class="gallery-grid">
    <figure class="gallery-card featured reveal">
      <img class="gallery-media" src="/assets/images/gallery/IMG_8149.JPG.jpeg" alt="Cyber Invasion Army gallery photo IMG 8149"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-1">
      <img class="gallery-media" src="/assets/images/gallery/IMG_8155.JPEG" alt="Cyber Invasion Army gallery photo IMG 8155" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-2">
      <img class="gallery-media" src="/assets/images/gallery/IMG_8133.jpg" alt="Cyber Invasion Army gallery photo IMG 8133" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-3">
      <img class="gallery-media" src="/assets/images/gallery/IMG_8119.jpg" alt="Cyber Invasion Army gallery photo IMG 8119" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal">
      <img class="gallery-media" src="/assets/images/gallery/IMG_8046.jpg" alt="Cyber Invasion Army gallery photo IMG 8046" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-1">
      <img class="gallery-media" src="/assets/images/gallery/IMG_7303.jpg" alt="Cyber Invasion Army gallery photo IMG 7303" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-2">
      <img class="gallery-media" src="/assets/images/gallery/IMG_6809.jpg" alt="Cyber Invasion Army gallery photo IMG 6809" loading="lazy"/>
    </figure>
    <figure class="gallery-card reveal reveal-delay-3">
      <img class="gallery-media" src="/assets/images/gallery/IMG_3614.jpg" alt="Cyber Invasion Army gallery photo IMG 3614" loading="lazy"/>
    </figure>
  </div>
</section>
</Layout>

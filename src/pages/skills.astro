---
import Layout from '../layouts/Layout.astro';
---
<Layout title="CIA">
<section id="skills" class="section-pad">
  <div class="section-header reveal">
    <div class="section-eyebrow">Capabilities</div>
    <h2 class="section-title">Our <span>Arsenal</span></h2>
    <p class="section-desc">The tools and techniques we deploy across every competition.</p>
  </div>
  <div class="skills-layout" style="max-width:1100px;margin:0 auto">
    <div class="reveal reveal-delay-1">
      <div class="skill-group-title">Core Attack Vectors</div>
      <div class="skill-bars">
        <div class="skill-bar-item">
          <div class="skill-bar-label">Web Exploitation<span>90%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill fill-indigo" data-width="90"></div></div>
        </div>
        <div class="skill-bar-item">
          <div class="skill-bar-label">Cryptography<span>82%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill fill-pink" data-width="82"></div></div>
        </div>
        <div class="skill-bar-item">
          <div class="skill-bar-label">Reverse Engineering<span>78%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill fill-cyan" data-width="78"></div></div>
        </div>
        <div class="skill-bar-item">
          <div class="skill-bar-label">Binary / Pwn<span>70%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill fill-amber" data-width="70"></div></div>
        </div>
        <div class="skill-bar-item">
          <div class="skill-bar-label">OSINT<span>85%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill fill-indigo" data-width="85"></div></div>
        </div>
      </div>
    </div>
    <div class="reveal reveal-delay-2">
      <div class="skill-group-title">Tools & Technologies</div>
      <div class="skill-bars">
        <div class="skill-bar-item">
          <div class="skill-bar-label">Forensics / Stego<span>80%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill fill-pink" data-width="80"></div></div>
        </div>
        <div class="skill-bar-item">
          <div class="skill-bar-label">Malware Analysis<span>65%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill fill-cyan" data-width="65"></div></div>
        </div>
        <div class="skill-bar-item">
          <div class="skill-bar-label">Network Security<span>75%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill fill-amber" data-width="75"></div></div>
        </div>
        <div class="skill-bar-item">
          <div class="skill-bar-label">Linux / Shell<span>88%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill fill-indigo" data-width="88"></div></div>
        </div>
        <div class="skill-bar-item">
          <div class="skill-bar-label">Python Scripting<span>84%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill fill-pink" data-width="84"></div></div>
        </div>
      </div>
      <div class="tech-chips">
        <span class="chip">Burp Suite</span>
        <span class="chip">GDB / PWNDBG</span>
        <span class="chip">Ghidra</span>
        <span class="chip">Wireshark</span>
        <span class="chip">Metasploit</span>
        <span class="chip">IDA Pro</span>
        <span class="chip">Radare2</span>
        <span class="chip">SQLmap</span>
        <span class="chip">Volatility</span>
        <span class="chip">CyberChef</span>
        <span class="chip">Python</span>
        <span class="chip">Bash</span>
      </div>
    </div>
  </div>
</section>
</Layout>
